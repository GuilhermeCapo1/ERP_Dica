generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User { 
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  email    String    @unique
  name     String?
  cargo    String?
  password String
  projetosResponsavel Projeto[] @relation("Responsavel")
  projetosProjetista  Projeto[] @relation("Projetista")
}

model Projeto {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  nome          String
  cliente       String
  feira         String?
  metragem      Float?
  datas         String?
  local         String?
  briefing      String?
  dataLimite    DateTime?
  arquivos      String?
  status        String   @default("Recebido")
  tipo          String?
  responsavelId String?  @db.ObjectId
  responsavel   User?    @relation("Responsavel", fields: [responsavelId], references: [id])
  projetistaId  String?  @db.ObjectId
  projetista    User?    @relation("Projetista", fields: [projetistaId], references: [id])
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
}