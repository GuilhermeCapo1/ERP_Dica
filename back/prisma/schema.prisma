generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User { 
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  email    String    @unique
  name     String?
  cargo    String?
  password String
  projetosResponsavel Projeto[]      @relation("Responsavel")
  projetosProjetista  Projeto[]      @relation("Projetista")
  memoriais           Memorial[]
}

model Projeto {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  nome          String
  cliente       String
  feira         String?
  metragem      Float?
  datas         String?
  local         String?
  briefing      String?
  dataLimite    DateTime?
  arquivos      String?
  status        String          @default("Recebido")
  tipo          String?
  responsavelId String?         @db.ObjectId
  responsavel   User?           @relation("Responsavel", fields: [responsavelId], references: [id])
  projetistaId  String?         @db.ObjectId
  projetista    User?           @relation("Projetista", fields: [projetistaId], references: [id])
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt
  imagensProjeto ImagemProjeto[]
  memoriais      Memorial[]
}

// Imagens enviadas pelo projetista após concluir o projeto
// (renders, plantas, elevações — aparecem no memorial)
model ImagemProjeto {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  projetoId  String   @db.ObjectId
  projeto    Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  filename   String
  url        String
  ordem      Int      @default(0)
  criadoEm  DateTime @default(now())
}

// Memorial descritivo — pode ter múltiplas versões por projeto
model Memorial {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  projetoId           String   @db.ObjectId
  projeto             Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  versao              Int      @default(1)

  // Os 6 campos de conteúdo (texto livre)
  piso                String?
  estrutura           String?
  areaAtendimento     String?
  audioVisual         String?
  comunicacaoVisual   String?
  eletrica            String?

  // Quais seções aparecem no PDF (JSON: array de strings com os campos ativos)
  // Ex: ["piso","estrutura","eletrica"]
  camposAtivos        String   @default("[\"piso\",\"estrutura\",\"areaAtendimento\",\"audioVisual\",\"comunicacaoVisual\",\"eletrica\"]")

  // Ordem das imagens no PDF (JSON: array de IDs de ImagemProjeto em ordem)
  ordemImagens        String   @default("[]")

  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
  criadoPorId        String?  @db.ObjectId
  criadoPor          User?    @relation(fields: [criadoPorId], references: [id])
}
