generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                  String      @id @default(auto()) @map("_id") @db.ObjectId
  email               String      @unique
  name                String?
  cargo               String?
  password            String
  projetosResponsavel Projeto[]   @relation("Responsavel")
  projetosProjetista  Projeto[]   @relation("Projetista")
  memoriais           Memorial[]
  orcamentos          Orcamento[]
}

model Projeto {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  nome           String
  cliente        String
  feira          String?
  metragem       Float?
  datas          String?
  local          String?
  briefing       String?
  dataLimite     DateTime?

  // Arquivos de briefing salvos como JSON nativo no MongoDB
  // Estrutura: { manual?: {url, nome}, mapa?: {url, nome}, briefing?: {url, nome}, logos?: [{url, nome}] }
  arquivos       Json?

  status         String          @default("Recebido")
  tipo           String?
  responsavelId  String?         @db.ObjectId
  responsavel    User?           @relation("Responsavel", fields: [responsavelId], references: [id])
  projetistaId   String?         @db.ObjectId
  projetista     User?           @relation("Projetista", fields: [projetistaId], references: [id])
  criadoEm       DateTime        @default(now())
  atualizadoEm   DateTime        @updatedAt
  imagensProjeto ImagemProjeto[]
  memoriais      Memorial[]
  orcamentos     Orcamento[]

  resultadoFinal       String?
  clienteId            String?  @db.ObjectId
  clienteRef           Cliente? @relation(fields: [clienteId], references: [id])
  formaPagamento       String?
  tipoDocumento        String?
  condicoesPagamento   String?
  observacoesAprovacao String?
}

model ImagemProjeto {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projetoId String   @db.ObjectId
  projeto   Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  ordem     Int      @default(0)
  criadoEm DateTime @default(now())
}

model Memorial {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId
  projetoId         String     @db.ObjectId
  projeto           Projeto    @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  versao            Int        @default(1)
  piso              String?
  estrutura         String?
  areaAtendimento   String?
  audioVisual       String?
  comunicacaoVisual String?
  eletrica          String?
  camposAtivos      String     @default("[\"piso\",\"estrutura\",\"areaAtendimento\",\"audioVisual\",\"comunicacaoVisual\",\"eletrica\"]")
  ordemImagens      String     @default("[]")
  criadoEm         DateTime   @default(now())
  atualizadoEm     DateTime   @updatedAt
  criadoPorId      String?    @db.ObjectId
  criadoPor        User?      @relation(fields: [criadoPorId], references: [id])
  orcamento        Orcamento?
}

model Orcamento {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  projetoId      String    @db.ObjectId
  projeto        Projeto   @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  memorialId     String    @unique @db.ObjectId
  memorial       Memorial  @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  versao         Int       @default(1)
  itens          String    @default("[]")
  formaPagamento String?
  vencimentos    String?
  cidade         String?   @default("São Paulo")
  dataOrcamento  DateTime  @default(now())
  enviado        Boolean   @default(false)
  enviadoEm      DateTime?
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  criadoPorId   String?   @db.ObjectId
  criadoPor     User?     @relation(fields: [criadoPorId], references: [id])
}

model Cliente {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  nomeEmpresa  String
  nomeFantasia String?
  cnpj         String?
  cpf          String?
  email        String?
  telefone     String?
  endereco     String?
  cidade       String?
  estado       String?
  cep          String?
  responsavel  String?
  criadoEm    DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  projetos     Projeto[]
}
